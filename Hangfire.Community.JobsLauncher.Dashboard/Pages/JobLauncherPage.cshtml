    // ====== BUILD REQUEST OBJECT ======
    function convertToType(value, type, isComplex) {
        var isNullable = type.endsWith('?');
        var underlyingType = isNullable ? type.slice(0, -1).toLowerCase() : type.toLowerCase();
    
        if (isNullable && (value === '' || value === null || value === undefined)) {
            return null;
        }
    
        if (isComplex) {
            if (value === '' && isNullable) return null;
            try {
                return JSON.parse(value);
            } catch(e) {
                return value;
            }
        }
    
        if (underlyingType.includes('int') || underlyingType.includes('long') || 
            underlyingType.includes('short') || underlyingType.includes('byte')) {
            var num = parseInt(value, 10);
            return isNaN(num) ? (isNullable ? null : value) : num;
        }
        if (underlyingType.includes('double') || underlyingType.includes('float') || 
            underlyingType.includes('decimal') || underlyingType.includes('single')) {
            var num = parseFloat(value);
            return isNaN(num) ? (isNullable ? null : value) : num;
        }
        if (underlyingType.includes('bool')) {
            if (typeof value === 'boolean') return value;
            if (value === '' && isNullable) return null;
            return value === 'true' || value === '1' || value === 'on';
        }
        return value;
    }

    function buildRequest() {
        var mode = document.querySelector('input[name="launchMode"]:checked').value;
        var className = mode === 'assisted' ? $$('classNameAssisted').value.trim() : $$('classNameManual').value.trim();
        var methodName = mode === 'assisted' ? (function() {
            var idx = $$('methodSelect').value;
            return idx === '' ? '' : currentMethods[parseInt(idx)].methodName;
        })() : $$('methodNameManual').value.trim();

        var request = {
            mode: mode,
            className: className,
            methodName: methodName,
            queue: $$('queue').value.trim() || 'default',
            executionMode: document.querySelector('input[name="execMode"]:checked').value,
            includePerformContext: $$('chkPerformContext').checked,
            includeCancellationToken: $$('chkCancellationToken').checked,
            parameters: null,
            rawParametersJson: null
        };

        if (mode === 'manual') {
            request.rawParametersJson = $$('jsonParams').value.trim() || '{}';
        } else {
            var paramsObj = {};
            // Obtener todos los elementos con data-param-name dentro del contenedor, ordenadamente
            var allElements = document.querySelectorAll('#paramsContainer [data-param-name]');
            allElements.forEach(function(el) {
                var name = el.getAttribute('data-param-name');
                if (!name) return;
                // Si es un contenedor de lista
                if (el.classList.contains('list-container')) {
                    var elementType = el.getAttribute('data-element-type');
                    var inputs = el.querySelectorAll('.list-item input');
                    var values = [];
                    inputs.forEach(function(inp) {
                        if (inp.value.trim() !== '') {
                            values.push(convertToType(inp.value, elementType, false));
                        }
                    });
                    paramsObj[name] = values;
                }
                // Si es un contenedor de diccionario
                else if (el.classList.contains('dict-container')) {
                    var rows = el.querySelectorAll('.dict-row');
                    var obj = {};
                    rows.forEach(function(row) {
                        var keyInp = row.querySelector('.dict-key');
                        var valInp = row.querySelector('.dict-value');
                        if (keyInp && valInp && keyInp.value.trim() !== '') {
                            obj[keyInp.value] = valInp.value;
                        }
                    });
                    paramsObj[name] = obj;
                }
                // Caso normal (input, textarea, select)
                else {
                    var value;
                    if (el.type === 'checkbox') {
                        value = el.checked;
                    } else {
                        value = el.value;
                    }
                    // Intentar obtener la definición del parámetro para convertir correctamente
                    var paramDef = selectedMethod ? selectedMethod.parameters.find(function(p) { return p.name === name; }) : null;
                    if (paramDef) {
                        value = convertToType(value, paramDef.type, paramDef.isComplex);
                    }
                    paramsObj[name] = value;
                }
            });
            request.rawParametersJson = JSON.stringify(paramsObj);
            request.parameters = null;
        }

        if (request.executionMode === 'Schedule') {
            request.delayMinutes = parseInt($$('delayMinutes').value) || 30;
        }
        if (request.executionMode === 'ScheduleDateTime') {
            request.scheduledDateTime = $$('scheduledDateTime').value ? new Date($$('scheduledDateTime').value).toISOString() : null;
        }
        if (request.executionMode === 'Recurring') {
            request.cronExpression = $$('cronExpression').value.trim() || '* * * * *';
            if (mode === 'manual') {
                request.recurringEngine = $$('recurringEngine').value;
            }
        }
        if (request.executionMode === 'Continuation') {
            request.parentJobId = $$('parentJobId').value.trim();
        }
        return request;
    }

    // ====== PREVIEW ======
    function showPreview() {
        var req = buildRequest();
        var summary = 'Class: ' + req.className + '\nMethod: ' + req.methodName + '\nQueue: ' + req.queue +
                      '\nMode: ' + req.executionMode + '\nEngine: ' + (req.recurringEngine || 'Direct') +
                      '\nParameters: ' + (req.rawParametersJson || JSON.stringify(req.parameters));
        $$('previewContent').textContent = summary;
        $$('previewPanel').style.display = 'block';
    }

    // ====== SUBMIT / LAUNCH ======
    var pendingLaunchRequest = null;

    function submitJob() {
        var req = buildRequest();
        if (!req.className || !req.methodName) { alert('ClassName and MethodName are required.'); return; }

        if (isQueueCritical(req.queue)) {
            pendingLaunchRequest = req;
            $$('criticalQueueName').textContent = req.queue;
            $$('criticalJobSummary').textContent = 'Class: ' + req.className + '\nMethod: ' + req.methodName + '\nMode: ' + req.executionMode;
            $('#criticalConfirmModal').modal('show');
        } else {
            launchJob(req);
        }
    }

    function confirmedLaunch() {
        $('#criticalConfirmModal').modal('hide');
        if (pendingLaunchRequest) launchJob(pendingLaunchRequest);
    }

    function launchJob(req) {
        var formData = new FormData();
        formData.append('json', JSON.stringify(req));

        fetch(apiBaseUrl + '/api/launch', {
            method: 'POST',
            body: formData
        })
        .then(function(r) { return r.json(); })
          .then(function(result) {
              var alertDiv = $$('launchResult');
              alertDiv.style.display = 'block';
              if (result.success) {
                  alertDiv.className = 'alert alert-success';
                  alertDiv.innerHTML = 'Job launched successfully! <a href="' + result.link + '" target="_blank">' + result.jobId + '</a>';
                  loadQueues();
                  loadHistory();
              } else {
                  alertDiv.className = 'alert alert-danger';
                  alertDiv.textContent = 'Error: ' + (result.error || 'Unknown error');
              }
          }).catch(function(err) {
              var alertDiv = $$('launchResult');
              alertDiv.style.display = 'block';
              alertDiv.className = 'alert alert-danger';
              alertDiv.textContent = 'Network error: ' + err.message;
          });
    }

    // ====== HISTORY ======
    function loadHistory() {
        var dashboardBaseUrl = '@Url.To("/")';
        fetchJson(apiBaseUrl + '/api/history').then(function(entries) {
            var tbody = $$('historyTable').querySelector('tbody');
            tbody.innerHTML = '';
            entries.forEach(function(e) {
                var entryJson = JSON.stringify(e).replace(/'/g, "&#39;").replace(/"/g, "&quot;");
                var row = '<tr>' +
                    '<td>' + new Date(e.timestamp).toLocaleString() + '</td>' +
                    '<td><a href="' + dashboardBaseUrl + 'jobs/details/' + e.jobId + '" target="_blank">' + e.jobId + '</a></td>' +
                    '<td>' + e.className + '</td>' +
                    '<td>' + e.methodName + '</td>' +
                    '<td>' + e.queue + '</td>' +
                    '<td>' + e.mode + '</td>' +
                    '<td>' + e.engine + '</td>' +
                    '<td>' +
                    '<button class="btn btn-xs btn-default relaunch" title="Load parameters into Launch tab for editing" data-entry=\'' + entryJson + '\'>Relaunch</button> ' +
                    '<button class="btn btn-xs btn-default clone-launch" title="Clone and launch immediately without editing" data-entry=\'' + entryJson + '\'>Clone & Launch</button> ' +
                    '<button class="btn btn-xs btn-primary save-as-template" title="Save this job configuration as a template" data-entry=\'' + entryJson + '\'>Save as template</button>' +
                    '</td>' +
                    '</tr>';
                tbody.innerHTML += row;
            });
            // Bind events
            document.querySelectorAll('.relaunch').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var entry = JSON.parse(this.getAttribute('data-entry'));
                    loadEntryToForm(entry);
                    document.querySelector('.nav-tabs a[href="#launchTab"]').click();
                });
            });
            document.querySelectorAll('.clone-launch').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var entry = JSON.parse(this.getAttribute('data-entry'));
                    if (confirm('Clone and launch job with same parameters?')) {
                        var req = buildRequestFromHistory(entry);
                        launchJob(req);
                    }
                });
            });
            document.querySelectorAll('.save-as-template').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var entry = JSON.parse(this.getAttribute('data-entry'));
                    saveEntryAsTemplate(entry);
                });
            });
        });
    }

    function clearHistory() {
        if (!confirm('Clear history?')) return;
        fetch(apiBaseUrl + '/api/history', { method: 'DELETE' }).then(function() { loadHistory(); });
    }

    function loadEntryToForm(entry) {
        var mode = entry.mode || (entry.rawParametersJson && !entry.parameters ? 'manual' : 'assisted');
        var radio = document.querySelector('input[name="launchMode"][value="' + mode + '"]');
        if (radio) radio.checked = true;
        toggleMode();

        $$('queue').value = entry.queue || 'default';
        $$('chkPerformContext').checked = entry.includePerformContext || false;
        $$('chkCancellationToken').checked = entry.includeCancellationToken || false;

        if (entry.executionMode) {
            var execRadio = document.querySelector('input[name="execMode"][value="' + entry.executionMode + '"]');
            if (execRadio) execRadio.checked = true;
            toggleExecMode();
        }

        if (entry.cronExpression) $$('cronExpression').value = entry.cronExpression;
        if (entry.delayMinutes) $$('delayMinutes').value = entry.delayMinutes;
        if (entry.scheduledDateTime) {
            var dt = new Date(entry.scheduledDateTime);
            if (!isNaN(dt)) {
                var local = new Date(dt.getTime() - dt.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
                $$('scheduledDateTime').value = local;
            }
        }
        if (entry.parentJobId) $$('parentJobId').value = entry.parentJobId;
        if (entry.recurringEngine) {
            var engineSelect = $$('recurringEngine');
            if (engineSelect) engineSelect.value = entry.recurringEngine;
        }

        if (mode === 'manual') {
            $$('classNameManual').value = entry.className || '';
            $$('methodNameManual').value = entry.methodName || '';
            $$('jsonParams').value = entry.parametersJson || '{}';
        } else {
            $$('classNameAssisted').value = entry.className || '';
            if (entry.className && entry.methodName) {
                loadMethodsForTemplate(entry.className, entry.methodName, entry.parametersJson);
            } else {
                $$('methodSelectGroup').style.display = 'none';
                $$('paramsContainer').innerHTML = '';
            }
        }
    }

    function buildRequestFromHistory(entry) {
        return {
            mode: entry.mode,
            className: entry.className,
            methodName: entry.methodName,
            queue: entry.queue,
            executionMode: entry.executionMode,
            cronExpression: entry.cronExpression,
            delayMinutes: entry.delayMinutes,
            scheduledDateTime: entry.scheduledDateTime,
            parentJobId: entry.parentJobId,
            recurringEngine: entry.engine === 'DynamicJobs' ? 'DynamicJobs' : 'BuiltIn',
            includePerformContext: entry.includePerformContext,
            includeCancellationToken: entry.includeCancellationToken,
            rawParametersJson: entry.parametersJson,
            parameters: null
        };
    }

    // ====== TEMPLATES ======
    function loadTemplates() {
        fetchJson(apiBaseUrl + '/api/templates').then(function(templates) {
            var tbody = $$('templatesTable').querySelector('tbody');
            tbody.innerHTML = '';
            templates.forEach(function(t) {
                var row = '<tr>' +
                    '<td>' + t.name + '</td>' +
                    '<td>' + t.className + '</td>' +
                    '<td>' + t.methodName + '</td>' +
                    '<td>' + t.queue + '</td>' +
                    '<td>' + t.executionMode + '</td>' +
                    '<td>' +
                    '<button class="btn btn-xs btn-default load-template" data-name="' + t.name + '">Load</button> ' +
                    '<button class="btn btn-xs btn-default clone-template" data-name="' + t.name + '">Clone & Launch</button> ' +
                    '<button class="btn btn-xs btn-danger delete-template" data-name="' + t.name + '">Delete</button> ' +
                    '<button class="btn btn-xs btn-info export-template" data-name="' + t.name + '">Export</button> ' +
                    '<button class="btn btn-xs btn-default preview-template" data-name="' + t.name + '">Preview</button>' +
                    '</td>' +
                    '</tr>';
                tbody.innerHTML += row;
            });
            bindTemplateEvents();
        });
    }

    function bindTemplateEvents() {
        document.querySelectorAll('.load-template').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var name = this.getAttribute('data-name');
                fetchJson(apiBaseUrl + '/api/templates?name=' + encodeURIComponent(name))
                    .then(function(t) { loadTemplateToForm(t); document.querySelector('.nav-tabs a[href="#launchTab"]').click(); });
            });
        });
        document.querySelectorAll('.clone-template').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var name = this.getAttribute('data-name');
                fetchJson(apiBaseUrl + '/api/templates?name=' + encodeURIComponent(name))
                    .then(function(t) {
                        var req = buildRequestFromTemplate(t);
                        if (confirm('Clone and launch?')) launchJob(req);
                    });
            });
        });
        document.querySelectorAll('.delete-template').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var name = this.getAttribute('data-name');
                if (confirm('Delete template ' + name + '?')) {
                    fetch(apiBaseUrl + '/api/templates?name=' + encodeURIComponent(name), { method: 'DELETE' })
                        .then(function() { loadTemplates(); });
                }
            });
        });
        document.querySelectorAll('.export-template').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var name = this.getAttribute('data-name');
                var downloadUrl = apiBaseUrl + '/api/export-import?action=export&templateName=' + encodeURIComponent(name);
                fetch(downloadUrl)
                    .then(function(response) { return response.blob(); })
                    .then(function(blob) {
                        var url = URL.createObjectURL(blob);
                        var a = document.createElement('a');
                        a.href = url;
                        a.download = name + '.json';
                        document.body.appendChild(a);
                        a.click();
                        document.body.removeChild(a);
                        URL.revokeObjectURL(url);
                    })
                    .catch(function(err) { alert('Error downloading template: ' + err.message); });
            });
        });
        document.querySelectorAll('.preview-template').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var name = this.getAttribute('data-name');
                fetchJson(apiBaseUrl + '/api/templates?name=' + encodeURIComponent(name))
                    .then(function(template) {
                        $$('previewTemplateName').textContent = template.name;
                        $$('prevClass').textContent = template.className || '';
                        $$('prevMethod').textContent = template.methodName || '';
                        $$('prevQueue').textContent = template.queue || 'default';
                        $$('prevExecMode').textContent = template.executionMode || '';
                        $$('prevCron').textContent = template.cronExpression || 'N/A';
                        $$('prevEngine').textContent = template.recurringEngine || (template.engine || 'N/A');
                        $$('prevMode').textContent = template.mode || 'N/A';
                        $$('prevPerformContext').textContent = template.includePerformContext ? 'Yes' : 'No';
                        $$('prevCancellationToken').textContent = template.includeCancellationToken ? 'Yes' : 'No';

                        // Parámetros en JSON formateado
                        var rawParams = template.rawParametersJson || '{}';
                        try {
                            var parsed = JSON.parse(rawParams);
                            $$('prevParams').textContent = JSON.stringify(parsed, null, 2);
                        } catch(e) {
                            $$('prevParams').textContent = rawParams;
                        }
                        $('#templatePreviewModal').modal('show');
                    });
            });
        });
    }

    function saveCurrentAsTemplate() {
        var req = buildRequest();
        if (!req.className || !req.methodName) {
            alert('Please configure a class and method before saving as template.');
            return;
        }
        var name = prompt('Template name:', req.className + '.' + req.methodName);
        if (!name) return;

        var template = {
            name: name,
            mode: req.mode,
            className: req.className,
            methodName: req.methodName,
            queue: req.queue,
            executionMode: req.executionMode,
            cronExpression: req.cronExpression,
            delayMinutes: req.delayMinutes,
            scheduledDateTime: req.scheduledDateTime,
            parentJobId: req.parentJobId,
            recurringEngine: req.recurringEngine,
            includePerformContext: req.includePerformContext,
            includeCancellationToken: req.includeCancellationToken,
            rawParametersJson: req.rawParametersJson,
            parameters: req.parameters
        };

        var formData = new FormData();
        formData.append('json', JSON.stringify(template));
        fetch(apiBaseUrl + '/api/templates', { method: 'POST', body: formData })
            .then(function(r) { return r.json(); })
            .then(function(res) {
                if (res.success) {
                    alert('Template "' + name + '" saved.');
                    loadTemplates();
                } else {
                    alert('Error: ' + (res.error || res.message));
                }
            });
    }

    function loadTemplateToForm(template) {
        var mode = template.mode;
        if (!mode) {
            inferModeAndLoad(template);
            return;
        }
        var radio = document.querySelector('input[name="launchMode"][value="' + mode + '"]');
        if (radio) radio.checked = true;
        toggleMode();
        fillCommonFields(template);
        if (template.executionMode) {
            var execRadio = document.querySelector('input[name="execMode"][value="' + template.executionMode + '"]');
            if (execRadio) execRadio.checked = true;
            toggleExecMode();
            fillExecModeFields(template);
        }
        if (mode === 'manual') {
            fillManualFields(template);
        } else {
            fillAssistedFieldsForTemplate(template);
        }
    }

    function loadMethodsForTemplate(className, methodName, rawParametersJson) {
        fetchJson(apiBaseUrl + '/api/methods?className=' + encodeURIComponent(className))
            .then(function(resp) {
                if (!resp.success) {
                    document.querySelector('input[name="launchMode"][value="manual"]').checked = true;
                    toggleMode();
                    $$('classNameManual').value = className;
                    $$('methodNameManual').value = methodName;
                    $$('jsonParams').value = rawParametersJson || '{}';
                    return;
                }
                currentMethods = resp.methods;
                var sel = $$('methodSelect');
                sel.innerHTML = '<option value="">-- Select method --</option>';
                var targetIndex = -1;
                currentMethods.forEach(function(m, i) {
                    var params = m.parameters.map(function(p) { return p.name; }).join(', ');
                    var display = m.methodName + '(' + params + ')';
                    sel.innerHTML += '<option value="' + i + '">' + display + '</option>';
                    if (m.methodName === methodName) targetIndex = i;
                });
                $$('methodSelectGroup').style.display = 'block';
                if (targetIndex >= 0) {
                    sel.value = targetIndex;
                    selectedMethod = currentMethods[targetIndex];
                    onMethodChange();
                    if (rawParametersJson) {
                        try {
                            var paramsObj = JSON.parse(rawParametersJson);
                            fillAssistedFields(paramsObj);
                        } catch(e) {}
                    }
                } else {
                    $$('paramsContainer').innerHTML = '';
                }
            });
    }

    function inferModeAndLoad(template) {
        if (!template.className || !template.methodName) {
            template.mode = 'manual';
            loadTemplateToForm(template);
            return;
        }
        fetchJson(apiBaseUrl + '/api/methods?className=' + encodeURIComponent(template.className))
            .then(function(resp) {
                if (resp.success) {
                    template.mode = 'assisted';
                    updateTemplateModeSilently(template.name, 'assisted');
                } else {
                    template.mode = 'manual';
                    updateTemplateModeSilently(template.name, 'manual');
                }
            })
            .catch(function() {
                template.mode = 'manual';
            })
            .finally(function() {
                loadTemplateToForm(template);
            });
    }

    function updateTemplateModeSilently(templateName, mode) {
        if (!templateName) return;
        fetchJson(apiBaseUrl + '/api/templates?name=' + encodeURIComponent(templateName))
            .then(function(t) {
                t.mode = mode;
                var formData = new FormData();
                formData.append('json', JSON.stringify(t));
                fetch(apiBaseUrl + '/api/templates', { method: 'POST', body: formData });
            })
            .catch(function() {});
    }

    function fillCommonFields(template) {
        $$('queue').value = template.queue || 'default';
        $$('chkPerformContext').checked = template.includePerformContext || false;
        $$('chkCancellationToken').checked = template.includeCancellationToken || false;
    }

    function fillExecModeFields(template) {
        if (template.cronExpression) $$('cronExpression').value = template.cronExpression;
        if (template.delayMinutes) $$('delayMinutes').value = template.delayMinutes;
        if (template.scheduledDateTime) {
            var dt = new Date(template.scheduledDateTime);
            if (!isNaN(dt)) {
                var local = new Date(dt.getTime() - dt.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
                $$('scheduledDateTime').value = local;
            }
        }
        if (template.parentJobId) $$('parentJobId').value = template.parentJobId;
        if (template.recurringEngine) {
            var engineSelect = $$('recurringEngine');
            if (engineSelect) engineSelect.value = template.recurringEngine;
        }
    }

    function fillManualFields(template) {
        $$('classNameManual').value = template.className || '';
        $$('methodNameManual').value = template.methodName || '';
        $$('jsonParams').value = template.rawParametersJson || '{}';
    }

    function fillAssistedFieldsForTemplate(template) {
        $$('classNameAssisted').value = template.className || '';
        if (template.className && template.methodName) {
            loadMethodsForTemplate(template.className, template.methodName, template.rawParametersJson);
        } else {
            $$('methodSelectGroup').style.display = 'none';
            $$('paramsContainer').innerHTML = '';
        }
    }

    function fillAssistedFields(paramsObj) {
        // Primero procesar listas y diccionarios
        document.querySelectorAll('#paramsContainer .list-container').forEach(function(container) {
            var name = container.getAttribute('data-param-name');
            var arr = paramsObj[name];
            if (arr && Array.isArray(arr)) {
                var elementType = container.getAttribute('data-element-type');
                var itemsDiv = container.querySelector('.list-items');
                itemsDiv.innerHTML = '';
                arr.forEach(function(val) {
                    var html = createListItem(elementType);
                    itemsDiv.insertAdjacentHTML('beforeend', html);
                    var lastInput = itemsDiv.lastElementChild.querySelector('input');
                    if (lastInput) lastInput.value = val != null ? val : '';
                });
            }
        });
        document.querySelectorAll('#paramsContainer .dict-container').forEach(function(container) {
            var name = container.getAttribute('data-param-name');
            var obj = paramsObj[name];
            if (obj && typeof obj === 'object' && !Array.isArray(obj)) {
                var keyType = container.getAttribute('data-key-type');
                var valueType = container.getAttribute('data-value-type');
                var tbody = container.querySelector('.dict-items tbody');
                tbody.innerHTML = '';
                Object.keys(obj).forEach(function(key) {
                    var html = createDictRow(keyType, valueType);
                    tbody.insertAdjacentHTML('beforeend', html);
                    var row = tbody.lastElementChild;
                    row.querySelector('.dict-key').value = key;
                    row.querySelector('.dict-value').value = obj[key] != null ? obj[key] : '';
                });
            }
        });
        // Luego los campos normales (inputs, selects, textareas)
        var fields = document.querySelectorAll('#paramsContainer .param-field');
        fields.forEach(function(field) {
            var input = field.querySelector('[data-param-name]:not(.list-container):not(.dict-container)');
            if (!input) return;
            var name = input.getAttribute('data-param-name');
            if (paramsObj.hasOwnProperty(name)) {
                var value = paramsObj[name];
                if (input.type === 'checkbox') {
                    input.checked = (value === true || value === 'true');
                } else if (input.type === 'number') {
                    input.value = value != null ? value : '';
                } else if (input.type === 'datetime-local') {
                    if (value) {
                        var dt = new Date(value);
                        if (!isNaN(dt)) {
                            input.value = new Date(dt.getTime() - dt.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
                        }
                    }
                } else if (input.tagName === 'TEXTAREA') {
                    input.value = typeof value === 'string' ? value : JSON.stringify(value);
                } else if (input.tagName === 'SELECT') {
                    input.value = value != null ? value : '';
                } else {
                    input.value = value != null ? value : '';
                }
            }
        });
    }

    function buildRequestFromTemplate(template) {
        return {
            mode: template.mode,
            className: template.className,
            methodName: template.methodName,
            queue: template.queue,
            executionMode: template.executionMode,
            cronExpression: template.cronExpression,
            delayMinutes: template.delayMinutes,
            scheduledDateTime: template.scheduledDateTime,
            parentJobId: template.parentJobId,
            recurringEngine: template.recurringEngine,
            includePerformContext: template.includePerformContext,
            includeCancellationToken: template.includeCancellationToken,
            rawParametersJson: template.rawParametersJson,
            parameters: template.parameters
        };
    }

    function saveEntryAsTemplate(entry) {
        var name = prompt('Template name:', entry.className + '.' + entry.methodName);
        if (!name) return;
        var template = {
            name: name,
            mode: entry.mode,
            className: entry.className,
            methodName: entry.methodName,
            queue: entry.queue,
            executionMode: entry.executionMode,
            cronExpression: entry.cronExpression,
            delayMinutes: entry.delayMinutes,
            scheduledDateTime: entry.scheduledDateTime,
            parentJobId: entry.parentJobId,
            recurringEngine: entry.engine === 'DynamicJobs' ? 'DynamicJobs' : (entry.engine === 'Direct' ? null : entry.engine),
            includePerformContext: entry.includePerformContext,
            includeCancellationToken: entry.includeCancellationToken,
            rawParametersJson: entry.parametersJson,
            parameters: null
        };
        var formData = new FormData();
        formData.append('json', JSON.stringify(template));
        fetch(apiBaseUrl + '/api/templates', { method: 'POST', body: formData })
            .then(function(r) { return r.json(); })
            .then(function(res) {
                if (res.success) {
                    alert('Template "' + name + '" saved.');
                    loadTemplates();
                } else {
                    alert('Error: ' + (res.error || res.message));
                }
            });
    }

    function importTemplate() {
        var fileInput = $$('importFile');
        if (!fileInput.files[0]) { alert('Select a file.'); return; }
        var reader = new FileReader();
        reader.onload = function(e) {
            var template = JSON.parse(e.target.result);
            var formData = new FormData();
            formData.append('json', JSON.stringify(template));
            fetch(apiBaseUrl + '/api/templates', { method: 'POST', body: formData })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res.conflict) {
                        if (confirm(res.message + ' Overwrite?')) {
                            fetch(apiBaseUrl + '/api/templates', { method: 'POST', body: formData })
                                .then(function() { loadTemplates(); });
                        }
                    } else {
                        alert(res.message || 'Imported.');
                        loadTemplates();
                    }
                });
        };
        reader.readAsText(fileInput.files[0]);
    }
</script>