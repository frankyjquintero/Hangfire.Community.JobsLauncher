@* Generator: Template TypeVisibility: Internal GeneratePrettyNames: True Namespace: Hangfire.Community.JobLauncher.Dashboard.Pages *@
@using Hangfire.Dashboard
@using Hangfire.Dashboard.Pages
@using Hangfire.Community.JobsLauncher.Dashboard.Models
@using Hangfire.Community.JobsLauncher.Dashboard.Pages
@inherits Hangfire.Dashboard.RazorPage
@{
    Layout = new LayoutPage("Job Launcher");
    // Asumimos que la clase parcial tiene una propiedad CriticalQueues
}
<style>
    #paramsContainer .param-complex {
        border-left: 2px solid #ccc;
        padding-left: 10px;
        margin-bottom: 10px;
    }
    .param-complex label {
        font-weight: normal;
        font-style: italic;
    }
    #jsonParams {
        font-family: monospace;
    }
    .help-block .btn {
        margin-right: 5px;
    }
    .list-item, .dict-row {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 3px;
    }
    .list-item input, .dict-row input {
        flex: 1;
    }
    .list-item button, .dict-row button {
        flex-shrink: 0;
    }
</style>

<ul class="nav nav-tabs" role="tablist">
    <li role="presentation" class="active"><a href="#launchTab" aria-controls="launchTab" role="tab" data-toggle="tab">Launch</a></li>
    <li role="presentation"><a href="#historyTab" aria-controls="historyTab" role="tab" data-toggle="tab">History</a></li>
    <li role="presentation"><a href="#templatesTab" aria-controls="templatesTab" role="tab" data-toggle="tab">Templates</a></li>
</ul>

<div class="tab-content" style="padding-top:15px;">
    <!-- ==================== PESTAÑA LAUNCH ==================== -->
    <div role="tabpanel" class="tab-pane fade in active" id="launchTab">
        <div class="row">
            <div class="col-md-6">
                <div class="panel panel-default">
                    <div class="panel-heading">Job Configuration</div>
                    <div class="panel-body">
                        <div class="form-group">
                            <label>Mode</label>
                            <div>
                                <label class="radio-inline"><input type="radio" name="launchMode" value="assisted" checked> Assisted (assembly)</label>
                                <label class="radio-inline"><input type="radio" name="launchMode" value="manual"> Manual (JSON)</label>
                            </div>
                        </div>
                        <!-- Campos según modo -->
                        <div id="assistedFields">
                            <div class="form-group">
                                <label>Class Name</label>
                                <div class="input-group">
                                    <input type="text" id="classNameAssisted" class="form-control" placeholder="Namespace.ClassName">
                                    <span class="input-group-btn"><button class="btn btn-default" id="btnLoadMethods" type="button">Load Methods</button></span>
                                </div>
                            </div>
                            <div class="form-group" id="methodSelectGroup" style="display:none;">
                                <label>Method</label>
                                <select id="methodSelect" class="form-control"><option value="">-- Select method --</option></select>
                            </div>
                            <div id="paramsContainer"></div>
                        </div>
                        <div id="manualFields" style="display:none;">
                            <div class="form-group">
                                <label>Class Name</label>
                                <input type="text" id="classNameManual" class="form-control" placeholder="Namespace.ClassName">
                            </div>
                            <div class="form-group">
                                <label>Method Name</label>
                                <input type="text" id="methodNameManual" class="form-control" placeholder="MethodName">
                            </div>
                            <div class="form-group">
                                <label>Parameters (JSON)</label>
                                <textarea id="jsonParams" class="form-control" rows="6"
                                          placeholder='{"to":"email@example.com","subject":"Test"}'></textarea>
                                <div class="help-block">
                                    <button type="button" class="btn btn-xs btn-default" id="validateJsonBtn">Validate</button>
                                    <button type="button" class="btn btn-xs btn-default" id="formatJsonBtn">Format</button>
                                    <button type="button" class="btn btn-xs btn-info" id="suggestJsonBtn">Suggest JSON</button>
                                    <span id="jsonValidationMsg" class="text-danger" style="display:none;">Invalid JSON</span>
                                </div>
                            </div>
                        </div>
                        <!-- Opciones avanzadas -->
                        <div class="form-group">
                            <a role="button" data-toggle="collapse" href="#advancedOptions" aria-expanded="false">Advanced options ▾</a>
                            <div class="collapse" id="advancedOptions" style="margin-top:5px;">
                                <div class="checkbox">
                                    <label><input type="checkbox" id="chkPerformContext"> Include PerformContext</label>
                                </div>
                                <div class="checkbox">
                                    <label><input type="checkbox" id="chkCancellationToken"> Include CancellationToken</label>
                                </div>
                            </div>
                        </div>
                        <!-- Modo de ejecución -->
                        <div class="form-group">
                            <label>Execution Mode</label>
                            <div id="executionModeGroup">
                                <label class="radio-inline"><input type="radio" name="execMode" value="FireAndForget" checked> Fire & Forget</label>
                                <label class="radio-inline"><input type="radio" name="execMode" value="Schedule"> Schedule (minutes)</label>
                                <label class="radio-inline"><input type="radio" name="execMode" value="ScheduleDateTime"> Schedule (date)</label>
                                <label class="radio-inline"><input type="radio" name="execMode" value="Recurring"> Recurring</label>
                                <label class="radio-inline"><input type="radio" name="execMode" value="Continuation"> Continuation</label>
                            </div>
                        </div>
                        <!-- Campos específicos del modo de ejecución -->
                        <div id="scheduleFields" style="display:none;">
                            <div class="form-group">
                                <label>Delay (minutes)</label>
                                <input type="number" id="delayMinutes" class="form-control" min="1" value="30">
                            </div>
                        </div>
                        <div id="scheduleDateTimeFields" style="display:none;">
                            <div class="form-group">
                                <label>Scheduled Date (UTC)</label>
                                <input type="datetime-local" id="scheduledDateTime" class="form-control">
                            </div>
                        </div>
                        <div id="recurringFields" style="display:none;">
                            <div class="form-group">
                                <label>Cron Expression</label>
                                <div class="input-group">
                                    <input type="text" id="cronExpression" class="form-control" placeholder="* * * * *">
                                    <span class="input-group-btn"><button class="btn btn-default" id="btnValidateCron" type="button">Validate</button></span>
                                </div>
                                <div id="cronPreview" style="margin-top:5px; display:none;" class="text-info"></div>
                            </div>
                            <!-- Motor recurrente (solo visible en modo manual) -->
                            <div class="form-group" id="recurringEngineGroup" style="display:none;">
                                <label>Recurring Engine</label>
                                <select id="recurringEngine" class="form-control">
                                    <option value="BuiltIn">Built-in (lightweight)</option>
                                    <option value="DynamicJobs">DynamicJobs (advanced)</option>
                                </select>
                                <span id="dynamicJobsWarning" class="text-warning" style="display:none;">DynamicJobs no está instalado en el dashboard o workers.</span>
                            </div>
                        </div>
                        <div id="continuationFields" style="display:none;">
                            <div class="form-group">
                                <label>Parent Job Id</label>
                                <input type="text" id="parentJobId" class="form-control" placeholder="job-id">
                            </div>
                        </div>
                        <!-- Cola -->
                        <div class="form-group">
                            <label>Queue</label>
                            <input type="text" id="queue" class="form-control" list="queueList" value="default">
                            <datalist id="queueList"></datalist>
                            <span id="criticalQueueWarning" class="text-warning" style="display:none;">⚠ Esta cola requiere confirmación.</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="panel panel-default">
                    <div class="panel-heading">Actions</div>
                    <div class="panel-body">
                        <button type="button" class="btn btn-info btn-block" id="btnPreview">Preview</button>
                        <button type="button" class="btn btn-success btn-block" id="btnLaunch">Launch Job</button>
                        <button type="button" class="btn btn-warning btn-block" id="btnSaveAsTemplate" style="margin-top:5px;">Save as Template</button>
                        <div id="launchResult" class="alert" style="margin-top:10px; display:none;"></div>
                    </div>
                </div>
                <div class="panel panel-default" id="previewPanel" style="display:none;">
                    <div class="panel-heading">Preview</div>
                    <div class="panel-body"><pre id="previewContent"></pre></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ==================== PESTAÑA HISTORY ==================== -->
    <div role="tabpanel" class="tab-pane fade" id="historyTab">
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="row">
                    <div class="col-sm-6"><strong>Recent launches</strong></div>
                    <div class="col-sm-6 text-right"><button class="btn btn-sm btn-danger" id="btnClearHistory">Clear history</button></div>
                </div>
            </div>
            <div class="panel-body">
                <table class="table table-condensed" id="historyTable">
                    <thead><tr><th>Timestamp</th><th>JobId</th><th>Class</th><th>Method</th><th>Queue</th><th>Mode</th><th>Engine</th><th></th></tr></thead>
                    <tbody></tbody>
                </table>
                <div class="alert alert-info" style="margin-top:15px;">
                    <strong>About the buttons:</strong>
                    <ul style="margin-bottom:0;">
                        <li><strong>Relaunch:</strong> Loads this job's parameters into the Launch tab so you can review or modify them before launching.</li>
                        <li><strong>Clone & Launch:</strong> Immediately creates and enqueues an identical job without editing.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- ==================== PESTAÑA TEMPLATES ==================== -->
    <div role="tabpanel" class="tab-pane fade" id="templatesTab">
        <div class="row">
            <div class="col-md-8">
                <div class="panel panel-default">
                    <div class="panel-heading">Saved templates</div>
                    <div class="panel-body">
                        <table class="table table-condensed" id="templatesTable">
                            <thead><tr><th>Name</th><th>Class</th><th>Method</th><th>Queue</th><th>Mode</th><th></th></tr></thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="panel panel-default">
                    <div class="panel-heading">Manage</div>
                    <div class="panel-body">
                        <p><small>You can also create a template from any job in the <strong>History</strong> tab using the <em>Save as template</em> button.</small></p>
                        <div class="form-group" style="margin-top:10px;">
                            <label>Import template</label>
                            <input type="file" id="importFile" accept=".json">
                            <button id="btnImport" class="btn btn-default btn-block" style="margin-top:5px;">Import</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Modal para vista previa de plantilla -->
        <div class="modal fade" id="templatePreviewModal" tabindex="-1" role="dialog">
            <div class="modal-dialog modal-lg" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                        <h4 class="modal-title">Template Preview: <span id="previewTemplateName"></span></h4>
                    </div>
                    <div class="modal-body">
                        <dl class="dl-horizontal">
                            <dt>Class</dt><dd id="prevClass"></dd>
                            <dt>Method</dt><dd id="prevMethod"></dd>
                            <dt>Queue</dt><dd id="prevQueue"></dd>
                            <dt>Execution Mode</dt><dd id="prevExecMode"></dd>
                            <dt>Cron Expression</dt><dd id="prevCron"></dd>
                            <dt>Recurring Engine</dt><dd id="prevEngine"></dd>
                            <dt>Mode</dt><dd id="prevMode"></dd>
                            <dt>Perform Context</dt><dd id="prevPerformContext"></dd>
                            <dt>Cancellation Token</dt><dd id="prevCancellationToken"></dd>
                            <dt>Params (raw JSON)</dt>
                            <dd><pre id="prevParams" style="max-height:300px; overflow-y:auto; background:#f5f5f5; padding:10px;"></pre></dd>
                        </dl>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Confirmación para colas críticas -->
<div class="modal fade" id="criticalConfirmModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header"><h4 class="modal-title">Confirm Launch</h4></div>
            <div class="modal-body">
                <p>The queue <strong id="criticalQueueName"></strong> is marked as critical. Are you sure you want to launch this job?</p>
                <div><pre id="criticalJobSummary"></pre></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmCriticalLaunch">Confirm & Launch</button>
            </div>
        </div>
    </div>
</div>

<script>
    // ====== VARIABLES GLOBALES ======
    var currentMethods = [];        // array de MethodInfoDto
    var dynamicJobsAvailable = false;
    var criticalQueues =  [];
    var apiBaseUrl = '@Url.To("/joblauncher")';
    var selectedMethod = null; // almacenará el MethodInfoDto actual

    // ====== UTILIDADES ======
    function $$(id){ return document.getElementById(id); }
    function fetchJson(url, options){ return fetch(url, options).then(r => r.json()); }

    // ====== INICIALIZACIÓN ======
    document.addEventListener('DOMContentLoaded', function() {
        fetchJson(apiBaseUrl + '/api/capabilities').then(function(caps) {
            dynamicJobsAvailable = caps.dynamicJobsAvailable;
            adjustRecurringEngineDisplay();
        });
        loadQueues();
        bindEvents();
        loadHistory();
        loadTemplates();
    });

    function bindEvents() {
        // Modo
        var radios = document.querySelectorAll('input[name="launchMode"]');
        radios.forEach(function(r) { r.addEventListener('change', toggleMode); });

        // Load methods
        $$('btnLoadMethods').addEventListener('click', loadMethods);

        // Method select
        $$('methodSelect').addEventListener('change', onMethodChange);

        // Execution modes
        var execRadios = document.querySelectorAll('input[name="execMode"]');
        execRadios.forEach(function(r) { r.addEventListener('change', toggleExecMode); });

        // Validate/format JSON/ suggest
        $$('validateJsonBtn').addEventListener('click', validateJson);
        $$('formatJsonBtn').addEventListener('click', formatJson);
        $$('suggestJsonBtn').addEventListener('click', suggestJsonStructure);

        // Cron
        $$('btnValidateCron').addEventListener('click', validateCron);

        // Botones principales
        $$('btnPreview').addEventListener('click', showPreview);
        $$('btnLaunch').addEventListener('click', submitJob);
        $$('confirmCriticalLaunch').addEventListener('click', confirmedLaunch);

        // History
        $$('btnClearHistory').addEventListener('click', clearHistory);

        // Templates
        $$('btnImport').addEventListener('click', importTemplate);

        // Atajo Ctrl+Enter
        document.addEventListener('keydown', function(e) {
            if (e.ctrlKey && e.key === 'Enter') { e.preventDefault(); submitJob(); }
        });

        $$('btnSaveAsTemplate').addEventListener('click', saveCurrentAsTemplate);

        // Mostrar/esconder campos de ejecución
        toggleExecMode();
        toggleMode();
    }

    // ====== MODO ASISTIDO / MANUAL ======
    function toggleMode() {
        var mode = document.querySelector('input[name="launchMode"]:checked').value;
        if (mode === 'assisted') {
            $$('assistedFields').style.display = 'block';
            $$('manualFields').style.display = 'none';
        } else {
            $$('assistedFields').style.display = 'none';
            $$('manualFields').style.display = 'block';
        }
        toggleExecMode();
    }

    // ====== MODO DE EJECUCIÓN ======
    function toggleExecMode() {
        var mode = document.querySelector('input[name="execMode"]:checked').value;
        $$('scheduleFields').style.display = (mode === 'Schedule') ? 'block' : 'none';
        $$('scheduleDateTimeFields').style.display = (mode === 'ScheduleDateTime') ? 'block' : 'none';
        $$('recurringFields').style.display = (mode === 'Recurring') ? 'block' : 'none';
        $$('continuationFields').style.display = (mode === 'Continuation') ? 'block' : 'none';
        adjustRecurringEngineDisplay();
    }

    function adjustRecurringEngineDisplay() {
        var mode = document.querySelector('input[name="launchMode"]:checked').value;
        var execMode = document.querySelector('input[name="execMode"]:checked').value;
        if (execMode === 'Recurring' && mode === 'manual') {
            $$('recurringEngineGroup').style.display = 'block';
            var optDynamic = $$('recurringEngine').querySelector('option[value="DynamicJobs"]');
            if (!dynamicJobsAvailable) {
                optDynamic.disabled = true;
                $$('dynamicJobsWarning').style.display = 'inline';
            } else {
                optDynamic.disabled = false;
                $$('dynamicJobsWarning').style.display = 'none';
            }
        } else {
            $$('recurringEngineGroup').style.display = 'none';
        }
    }

    document.querySelectorAll('input[name="execMode"]').forEach(r => r.addEventListener('change', adjustRecurringEngineDisplay));
    document.querySelectorAll('input[name="launchMode"]').forEach(r => r.addEventListener('change', adjustRecurringEngineDisplay));

    // ====== CARGAR MÉTODOS (ASISTIDO) ======
    function loadMethods() {
        var className = $$('classNameAssisted').value.trim();
        if (!className) { alert('Class name required'); return; }
        fetchJson(apiBaseUrl + '/api/methods?className=' + encodeURIComponent(className))
            .then(function(resp) {
                if (!resp.success) {
                    alert(resp.error + ' Switched to manual mode.');
                    document.querySelector('input[name="launchMode"][value="manual"]').checked = true;
                    toggleMode();
                    return;
                }
                currentMethods = resp.methods;
                var sel = $$('methodSelect');
                sel.innerHTML = '<option value="">-- Select method --</option>';
                currentMethods.forEach(function(m, i) {
                    var params = m.parameters.map(function(p) { return p.name; }).join(', ');
                    var display = m.methodName + '(' + params + ')';
                    sel.innerHTML += '<option value="' + i + '">' + display + '</option>';
                });
                $$('methodSelectGroup').style.display = 'block';
                $$('paramsContainer').innerHTML = '';
            });
    }

    // ====== GENERAR PARÁMETROS DINÁMICOS (ASISTIDO) ======
    function onMethodChange() {
        var idx = $$('methodSelect').value;
        if (idx === '') { 
            $$('paramsContainer').innerHTML = ''; 
            selectedMethod = null; 
            return; 
        }
        var method = currentMethods[parseInt(idx)];
        selectedMethod = method;
        var html = '';
    
        method.parameters.forEach(function(p) {
            html += '<div class="form-group param-field">';
            html += '<label>' + p.name + ' (' + p.type + ')</label>';
        
            if (p.isComplex) {
                if (isListType(p.type)) {
                    html += generateListInput(p);
                } else if (isDictType(p.type)) {
                    html += generateDictionaryInput(p);
                } else {
                    html += '<textarea class="form-control param-complex" data-param-name="' + p.name + '" rows="3" placeholder=\'Insert JSON for ' + p.type + '\'></textarea>';
                }
            } else {
                html += generateInputForSimpleType(p);
            }
            html += '</div>';
        });
        $$('paramsContainer').innerHTML = html;

        // Bindear eventos para listas y diccionarios
        document.querySelectorAll('.add-list-item').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                var container = this.closest('.list-container');
                var elementType = container.getAttribute('data-element-type');
                var itemsDiv = container.querySelector('.list-items');
                var newItem = createListItem(elementType);
                itemsDiv.insertAdjacentHTML('beforeend', newItem);
                bindRemoveItem(itemsDiv);
            });
        });
        document.querySelectorAll('.add-dict-item').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                var container = this.closest('.dict-container');
                var keyType = container.getAttribute('data-key-type');
                var valueType = container.getAttribute('data-value-type');
                var tbody = container.querySelector('.dict-items tbody');
                var newRow = createDictRow(keyType, valueType);
                tbody.insertAdjacentHTML('beforeend', newRow);
                bindRemoveDictRow(tbody);
            });
        });
        function bindRemoveItem(container) {
            container.querySelectorAll('.remove-list-item').forEach(function(btn) {
                btn.onclick = function() { this.closest('.list-item').remove(); };
            });
        }
        function bindRemoveDictRow(tbody) {
            tbody.querySelectorAll('.remove-dict-row').forEach(function(btn) {
                btn.onclick = function() { this.closest('.dict-row').remove(); };
            });
        }
        // Inicializar remove en items ya existentes (si se regeneran los campos)
        document.querySelectorAll('.list-items').forEach(bindRemoveItem);
        document.querySelectorAll('.dict-items tbody').forEach(bindRemoveDictRow);
    }

    // Generadores de campos para listas y diccionarios
    function generateListInput(paramInfo) {
        var name = paramInfo.name;
        var elementType = extractGenericArgument(paramInfo.type, 0) || 'string';
        var html = '<div class="list-container" data-param-name="' + name + '" data-element-type="' + elementType + '">';
        html += '<label>' + name + ' (List of ' + elementType + ')</label>';
        html += '<div class="list-items"></div>';
        html += '<button type="button" class="btn btn-xs btn-default add-list-item">+ Add item</button>';
        html += '</div>';
        return html;
    }

    function generateDictionaryInput(paramInfo) {
        var name = paramInfo.name;
        var keyType = extractGenericArgument(paramInfo.type, 0) || 'string';
        var valueType = extractGenericArgument(paramInfo.type, 1) || 'string';
        var html = '<div class="dict-container" data-param-name="' + name + '" data-key-type="' + keyType + '" data-value-type="' + valueType + '">';
        html += '<label>' + name + ' (Dictionary<' + keyType + ', ' + valueType + '>)</label>';
        html += '<table class="table table-condensed dict-items"><tbody></tbody></table>';
        html += '<button type="button" class="btn btn-xs btn-default add-dict-item">+ Add entry</button>';
        html += '</div>';
        return html;
    }

    function createListItem(elementType) {
        var inputType = getInputTypeForSimple(elementType);
        return '<div class="list-item">' +
            '<input type="' + inputType + '" class="form-control input-sm" value="" />' +
            '<button type="button" class="btn btn-xs btn-danger remove-list-item">×</button>' +
            '</div>';
    }

    function createDictRow(keyType, valueType) {
        var keyInputType = getInputTypeForSimple(keyType);
        var valueInputType = getInputTypeForSimple(valueType);
        return '<tr class="dict-row">' +
            '<td><input type="' + keyInputType + '" class="form-control input-sm dict-key" placeholder="key" /></td>' +
            '<td><input type="' + valueInputType + '" class="form-control input-sm dict-value" placeholder="value" /></td>' +
            '<td><button type="button" class="btn btn-xs btn-danger remove-dict-row">×</button></td>' +
            '</tr>';
    }

    function getInputTypeForSimple(typeName) {
        var t = typeName.toLowerCase();
        if (t.includes('int') || t.includes('long') || t.includes('short') || t.includes('byte') ||
            t.includes('double') || t.includes('float') || t.includes('decimal')) return 'number';
        if (t.includes('datetime')) return 'datetime-local';
        if (t.includes('bool')) return 'checkbox';
        return 'text';
    }

    function isListType(type) {
        return type.startsWith('System.Collections.Generic.List') ||
               type.startsWith('System.Collections.Generic.IList') ||
               type.endsWith('[]');
    }

    function isDictType(type) {
        return type.startsWith('System.Collections.Generic.Dictionary');
    }

    function extractGenericArgument(typeName, index) {
        var match = typeName.match(/<(.+)>/);
        if (match) {
            var args = match[1].split(',');
            return args[index] ? args[index].trim() : null;
        }
        return null;
    }

    function generateInputForSimpleType(paramInfo) {
        var type = paramInfo.type;
        var name = paramInfo.name;
        var isNullable = type.endsWith('?');
        var underlyingType = isNullable ? type.slice(0, -1).toLowerCase() : type.toLowerCase();
    
        var html = '';
    
        if (underlyingType.includes('int') || underlyingType.includes('long') || 
            underlyingType.includes('short') || underlyingType.includes('byte')) {
            html = '<input type="number" class="form-control" data-param-name="' + name + '" step="1" value="' + (isNullable ? '' : '0') + '" />';
        }
        else if (underlyingType.includes('double') || underlyingType.includes('float') || 
                 underlyingType.includes('decimal') || underlyingType.includes('single')) {
            html = '<input type="number" class="form-control" data-param-name="' + name + '" step="any" value="' + (isNullable ? '' : '0.0') + '" />';
        }
        else if (underlyingType.includes('bool')) {
            html = '<select class="form-control" data-param-name="' + name + '">';
            if (isNullable) html += '<option value="">-- Not set --</option>';
            html += '<option value="true">True</option><option value="false">False</option>';
            html += '</select>';
        }
        else if (underlyingType.includes('datetime') || underlyingType.includes('datetimeoffset')) {
            var defaultDate = isNullable ? '' : new Date(new Date().getTime() - new Date().getTimezoneOffset() * 60000).toISOString().slice(0, 16);
            html = '<input type="datetime-local" class="form-control" data-param-name="' + name + '" value="' + defaultDate + '" />';
            html += '<small class="help-block">Click the calendar icon to select a date and time.</small>';
        }
        else if (underlyingType === 'system.datetime' || underlyingType === 'datetime') {
            var defaultDate = isNullable ? '' : new Date().toISOString().slice(0, 10);
            html = '<input type="date" class="form-control" data-param-name="' + name + '" value="' + defaultDate + '" />';
        }
        else if (underlyingType === 'system.guid' || underlyingType === 'guid') {
            html = '<input type="text" class="form-control" data-param-name="' + name + '" placeholder="00000000-0000-0000-0000-000000000000" value="' + (isNullable ? '' : '00000000-0000-0000-0000-000000000000') + '" />';
        }
        else if (underlyingType === 'system.timespan' || underlyingType === 'timespan') {
            html = '<input type="text" class="form-control" data-param-name="' + name + '" placeholder="hh:mm:ss" value="' + (isNullable ? '' : '00:00:00') + '" />';
        }
        else if (underlyingType.includes('.') && !underlyingType.startsWith('system.')) {
            if (paramInfo.enumValues && paramInfo.enumValues.length > 0) {
                html += '<select class="form-control" data-param-name="' + name + '">';
                paramInfo.enumValues.forEach(function(val) {
                    html += '<option value="' + val + '">' + val + '</option>';
                });
                html += '</select>';
            } else {
                html = '<input type="text" class="form-control" data-param-name="' + name + '" placeholder="Enum value of ' + paramInfo.type + '" />';
            }
        }
        else {
            html = '<input type="text" class="form-control" data-param-name="' + name + '" placeholder="' + paramInfo.type + '" />';
        }
    
        if (isNullable) {
            html += '<small class="text-muted">(Optional, leave empty for null)</small>';
        }
    
        return html;
    }

    // ====== JSON VALIDATE / FORMAT / SUGGEST ======
    function validateJson() {
        var text = $$('jsonParams').value.trim();
        if (!text) return;
        try { JSON.parse(text); $$('jsonValidationMsg').style.display = 'none'; alert('Valid JSON.'); }
        catch(e) { $$('jsonValidationMsg').style.display = 'inline'; }
    }
    function formatJson() {
        var text = $$('jsonParams').value.trim();
        try { var obj = JSON.parse(text); $$('jsonParams').value = JSON.stringify(obj, null, 2); $$('jsonValidationMsg').style.display = 'none'; }
        catch(e) { $$('jsonValidationMsg').style.display = 'inline'; }
    }

    function suggestJsonStructure() {
        var className = $$('classNameManual').value.trim();
        var methodName = $$('methodNameManual').value.trim();
    
        if (!className || !methodName) {
            alert('Please enter Class Name and Method Name first.');
            return;
        }
    
        fetchJson(apiBaseUrl + '/api/methods?className=' + encodeURIComponent(className))
            .then(function(resp) {
                if (!resp.success) {
                    alert('Assembly no disponible: ' + resp.error);
                    return;
                }
                var method = resp.methods.find(function(m) { return m.methodName === methodName; });
                if (!method) {
                    alert('Method not found.');
                    return;
                }
                var suggestion = {};
                method.parameters.forEach(function(p) {
                    suggestion[p.name] = getDefaultValueForType(p.type, p.isComplex);
                });
                $$('jsonParams').value = JSON.stringify(suggestion, null, 2);
            })
            .catch(function(err) {
                alert('Error loading suggestion: ' + err.message);
            });
    }

    function getDefaultValueForType(type, isComplex) {
        if (type.endsWith('?')) {
            return null;
        }
        if (isComplex) {
            return {};
        }
        var t = type.toLowerCase();
        if (t.includes('int') || t.includes('long') || t.includes('short') || t.includes('byte')) return 0;
        if (t.includes('double') || t.includes('float') || t.includes('decimal') || t.includes('single')) return 0.0;
        if (t.includes('bool')) return true;
        if (t.includes('datetime') || t.includes('datetimeoffset')) return new Date().toISOString();
        if (t === 'system.guid' || t === 'guid') return '00000000-0000-0000-0000-000000000000';
        if (t === 'system.timespan' || t === 'timespan') return '00:00:00';
        if (t === 'system.string' || t === 'string') return '';
        return '';
    }

    // ====== VALIDATE CRON ======
    function validateCron() {
        var expr = $$('cronExpression').value.trim();
        if (!expr) { alert('Cron expression required'); return; }
        fetchJson(apiBaseUrl + '/api/validate-cron?expression=' + encodeURIComponent(expr))
